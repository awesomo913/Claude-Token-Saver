#!/usr/bin/env bash
# Auto-rebuild ClaudeTokenSaver.exe in the background after every commit
# so the shipped binary on Desktop/My Apps/ClaudeTokenSaver/ tracks main
# without manual rebuilds.
#
# Wire via:  git config core.hooksPath .githooks
#
# Skips itself for commits that ONLY touch tests/, docs/, or *.md so a
# typo fix in the README doesn't trigger a 2-minute PyInstaller run.
set -e

repo_root="$(git rev-parse --show-toplevel)"

# Detect "noisy-only" commits we can skip the rebuild for.
changed=$(git diff-tree --no-commit-id --name-only -r HEAD)
needs_build=false
while IFS= read -r path; do
    case "$path" in
        claude_backend/*|ai/*|classifier/*|extension_native_bridge/*|extensions/*|gemini_coder/*|gemini_coder_web/*|ui/*|scripts/build_exe.py|scripts/ensure_exe_current.py|launch_token_saver.py|launch_tray.py|broadcast.py|patch_upstream.py|build_exe.py|requirements.txt|pyproject.toml)
            needs_build=true
            break
            ;;
    esac
done <<< "$changed"

if ! $needs_build; then
    exit 0
fi

# Fire the rebuilder in the background; the commit must NOT block on a
# 2-minute PyInstaller run. Output goes to logs/ for post-mortem.
mkdir -p "$repo_root/logs"
log="$repo_root/logs/post_commit_rebuild_$(date +%Y%m%d_%H%M%S).log"
nohup python "$repo_root/scripts/ensure_exe_current.py" --quiet \
    >"$log" 2>&1 < /dev/null &
disown 2>/dev/null || true
echo "[post-commit] background rebuild fired -> $log"
exit 0
